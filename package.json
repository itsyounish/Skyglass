{
  "name": "skyglass-cli",
  "version": "0.1.1",
  "description": "A looking glass for your cloud. Interactive 2D visualization of AWS, Azure, and GCP infrastructure.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "cloud",
    "infrastructure",
    "visualization",
    "aws",
    "azure",
    "gcp",
    "multi-cloud",
    "devops",
    "knowledge-graph",
    "canvas",
    "force-directed",
    "architecture-diagram"
  ],
  "author": "itsyounish",
  "homepage": "https://github.com/itsyounish/Skyglass#readme",
  "bugs": {
    "url": "https://github.com/itsyounish/Skyglass/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsyounish/Skyglass.git"
  },
  "bin": {
    "skyglass-cli": "bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "!src/**/__tests__/",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "public/",
    "index.html",
    "vite.config.ts",
    "tsconfig.json",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node bin/cli.js",
    "record-demo": "node scripts/record-demo.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
